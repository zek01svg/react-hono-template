{
  "name": "react-hono-template",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#server/*": "./server/*",
    "#client/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "NODE_ENV=production bun with-env bun dist/index.js",
    "build": "bun with-env vite build && bun build --minify --sourcemap --target=bun --outdir=dist server/index.ts",
    "build:docker": "docker build -t react-hono-template .",
    "preview": "bun with-env vite preview",
    "clean": "git clean -xdf .cache .turbo dist node_modules .tanstack",
    "dev:server": "bun run --hot server/index.ts",
    "dev:vite": "wait-on http://localhost:4001/health && bun with-env vite",
    "dev": "concurrently \"bun dev:server\" \"bun dev:vite\"",
    "format": "oxfmt --check .",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e .env --",
    "test": "vitest run",
    "auth:generate": "bun dlx @better-auth/cli generate --output server/drizzle/schema/auth.ts --config server/lib/auth.ts",
    "db:push": "bun with-env drizzle-kit push",
    "db:studio": "bun with-env drizzle-kit studio",
    "ui:add": "bunx --bun shadcn add"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/standard-validator": "^0.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@scalar/hono-api-reference": "^0.10.6",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.22",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.14",
    "hono-openapi": "^1.3.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "react": "19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.5",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.1",
