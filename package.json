    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/compat": "^2.0.5",
    "@tanstack/router-devtools": "^1.166.13",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "4.1.4",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "shadcn": "^4.3.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "8.0.9",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
